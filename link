#!/usr/bin/env bash
set -euo pipefail

ROOT="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
BACKUP="$HOME/.vim-backup/$(date +%Y%m%d-%H%M%S)"

echo "Linking vim configuration: $ROOT"

# dst -> src  (~/.vim points at the repo so native packages resolve)
link_one() {
    local src="$1" dst="$2" rel="${2#$HOME/}"
    if [ -L "$dst" ]; then
        unlink "$dst"
    elif [ -e "$dst" ]; then
        mkdir -p "$BACKUP"
        mv "$dst" "$BACKUP/${rel#.}"
        echo "  backed up ~/$rel"
    fi
    ln -s "$src" "$dst"
    echo "  linked ~/$rel"
}

link_one "$ROOT/.vimrc" "$HOME/.vimrc"
link_one "$ROOT"        "$HOME/.vim"

echo "Done."
